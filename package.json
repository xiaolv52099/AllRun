{
  "name": "allrun",
  "version": "1.0.0",
  "description": "macOS 剪切板管理器 - 支持历史记录、收藏、快捷指令",
  "main": "electron/main.cjs",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "icon:generate": "node scripts/generate-icon.cjs",
    "dev:preflight": "node scripts/dev-preflight.cjs",
    "dev:vite": "vite",
    "dev:electron": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "npm run dev:preflight && concurrently \"npm run dev:vite\" \"wait-on http-get://localhost:5173/@vite/client && npm run dev:electron\"",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.1.0"
  }
}
